{
  "_title": "European Integration Index — Data",
  "_description": "Composite index tracking European integration across four sub-indicators, 2006–2024. The composite is the arithmetic mean of the four sub-indicators. Each sub-indicator is rescaled to a 0–100 scale.",
  "_methodology": "See /colophon.html#index-methodology for full methodology note. Sub-indicators are: (A) public support for EU-level decision-making — Eurobarometer (real, sourced); (B) EDA collaborative defence procurement as % of total EU27 defence R&T spend — EDA Annual Reports (real, sourced); (C) EU budget as % of EU GDP compared to a federal reference (US federal budget as % of GDP) — both real, sourced (Commission; US OMB); (D) qualitative competence score — operator's own assessment of EU treaty competence vs. full federation, labeled [qualitative — see methodology].",
  "_sources": {
    "A_eurobarometer": "Standard Eurobarometer surveys, European Commission / DG Communication. https://europa.eu/eurobarometer/surveys/browse/all/series/4506",
    "B_eda": "European Defence Agency, Defence Data Portal and Annual Reports. https://eda.europa.eu/publications-and-data/defence-data",
    "C_eu_budget": "European Commission, EU Budget Statistics. https://commission.europa.eu/strategy-and-policy/eu-budget/documents_en",
    "C_us_omb": "US Office of Management and Budget, Historical Tables, Table 1.2. https://www.whitehouse.gov/omb/budget/historical-tables/",
    "C_eu_gdp": "Eurostat, nama_10_gdp. https://ec.europa.eu/eurostat/databrowser/view/nama_10_gdp"
  },
  "_scale_notes": {
    "A": "Rescaled: 35% favourable = 0; 70% favourable = 100.",
    "B": "Rescaled: 10% collaborative = 0; 40% collaborative = 100 (40% is EDA's stated aspirational target).",
    "C": "Rescaled: EU budget/GDP ÷ US federal budget/GDP × 100. Max at 100 when EU matches US ratio. Current EU ~1.1% vs US ~24% gives low score by design — this sub-indicator captures the fiscal distance to a federal reference.",
    "D": "[ILLUSTRATIVE — qualitative scoring] 0 = purely intergovernmental; 100 = full federation on par with Germany's Basic Law division of powers. Scoring methodology described in Colophon."
  },
